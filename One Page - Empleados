SELECT A.U6LOGO, A.U6ORG, A.DMACCT, B.DMNAME, A.U6CYCDUE, A.DMCURBAL,CAST(A.DMBRANCH AS INT)DMBRANCH, A.U6BLOCKCODE1, A.U6BLOCKCODE2,
CASE WHEN CAST(A.DMBRANCH AS INT) IN (1,2,3,5,6,7,81,87,103,176,456,1132,1135,1154) THEN 1
WHEN CAST(A.DMBRANCH AS INT) IN (4,29,80,83,104,170,180,186,195,199,766,1064,1157) THEN 2
