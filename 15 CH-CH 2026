SELECT /*+parallel (18)*/
U6ORG, 
DMAGENCY,
Riesgo, 
COUNT(DMACCT) Cuentas, 
SUM(DMCURBAL) Saldo, 
COUNT(PMACCT) Pagos, 
SUM(PMTAMT) Importe

FROM

(SELECT U6ORG, DMACCT, DMAGENCY, DMCURBAL, 
CASE WHEN DMLABEL5 IN ('NR0B','NR0M','NR0A','NRMB') THEN DMLABEL5
ELSE '' END AS Riesgo
FROM RCVRY.DELQUDA_BEGIN
WHERE TRUNC(BEGINDT) = '01-Jul-2026'
AND U6CYCDUE IN ('6','7','8','9')
AND (DMAGENCY LIKE 'DA%' OR DMAGENCY LIKE 'SA%' OR
     DMAGENCY LIKE 'DQA%')
AND DMAGENCY NOT IN ('SALDOABO')
) A

LEFT OUTER JOIN 

(SELECT PMACCT, SUM(PMTAMT) PMTAMT
FROM RCVRY.PMTFIL
WHERE TRUNC(PMEDATE) >= '01-Jul-2026' AND TRUNC(PMEDATE) <= '31-Jul-2026'
GROUP BY PMACCT) B

ON A.DMACCT = B.PMACCT

GROUP BY U6ORG, Riesgo, DMAGENCY
