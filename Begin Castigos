from
( select  /*+PARALLEL(8)*/ 
DMACCT, 
U6CHGOFFDATE, 
DMAGENCY, 
DMCURBAL, 
U6CYCDUE, 
DMLABEL6, 
DMACCTG 
from RCVRY.DELQUDA_BEGIN 
where trunc(BEGINDT) = TO_DATE('01-04-2026', 'DD-MM-YYYY')  
and (DMAGENCY like 'DK%' or DMAGENCY like 'LK%' or DMAGENCY like 'DKN00%') 
and DMAGENCY not like 'DKN01%'  
and DMAGENCY not like 'DKN02%'  and DMAGENCY not like 'DKN03%'  
and DMAGENCY not like 'DKN04%' and DMAGENCY not like 'DKN05%' ) A1  
left outer join  
( select
DMACCT, 
DMAGNREF, 
DMNAME, 
DMCURBAL, 
DMPPFLAG, 
DMPPDUE, 
DMPPAMT, 
DMPAYAMT, 
DMPAYDT, 
DMLSTACT, 
DMACCTG 
from RCVRY.DELQMST 
where DMACCT in ( select  /*+PARALLEL(32)*/  DMACCT
from RCVRY.DELQUDA_BEGIN                 
where trunc(BEGINDT) = TO_DATE('01-04-2026', 'DD-MM-YYYY')  
and (DMAGENCY like 'DK%' or DMAGENCY like 'LK%' or DMAGENCY like 'DKN00%')
and DMAGENCY not like 'DKN01%' 
and DMAGENCY not like 'DKN02%'
and DMAGENCY not like 'DKN03%'
and DMAGENCY not like 'DKN04%'                 
and DMAGENCY not like 'DKN05%') and DMACCTG = '6') A2 
on A1.DMACCT = A2.DMACCT AND A1.DMACCTG = A2.DMACCTG
