when A1.DMLABEL6 = '0105' then 'Celaya'         
when A1.DMLABEL6 = '0121' then 'Orizaba'         
when A1.DMLABEL6 = '0126' then 'Ciudad Victoria'         
when A1.DMLABEL6 = '0127' then 'Zacatecas'         
