when A1.DMLABEL6 = '0065' then 'Saltillo'         
when A1.DMLABEL6 = '0071' then 'León'         
when A1.DMLABEL6 = '0072' then 'Puebla'         
when A1.DMLABEL6 = 'M074' then 'Toluca'         
when A1.DMLABEL6 = '0075' then 'Cancún'         
when A1.DMLABEL6 = '0076' then 'Mérida'         
