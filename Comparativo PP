SELECT FECHA,
'',
SUM(CUMPLIDAS_TOTALES) AS CUMPLIDAS_TOTALES,
REPLACE(SUM(PENDIENTES_TOTALES),'',0) AS PENDIENTES_TOTALES,
SUM(TOTALES) AS TOTALES,
'',
SUM(CUMPLIDAS_LPC) AS CUMPLIDAS_LPC,
SUM(PENDIENTES_LCP) AS PENDIENTES_LCP,
SUM(TOTALES_LPC) AS TOTALES_LPC,
'',
SUM(CUMPLIDAS_DILISA) AS CUMPLIDAS_DILISA,
SUM(PENDIENTES_DILISA) AS PENDIENTES_DILISA,
SUM(TOTALES_DILISA) AS TOTALES_DILISA,
'',
SUM(CUMPLIDAS_SBB_VISA) AS CUMPLIDAS_SBB_VISA,
SUM(PENDIENTES_SBB_VISA) AS PENDIENTES_SBB_VISA,
SUM(TOTALES_SBB_VISA) AS TOTALES_SBB_VISA,
'',
SUM(CUMPLIDAS_SBB_TD) AS CUMPLIDAS_SBB_TD,
SUM(PENDIENTES_SBB_TD) AS PENDIENTES_SBB_TD,
SUM(TOTALES_SBB_TD) AS TOTALES_SBB_TD,
'',
SUM(CUMPLIDAS_MP) AS CUMPLIDAS_MP,
SUM(PENDIENTES_MP) AS PENDIENTES_MP,
SUM(TOTALES_MP) AS TOTALES_MP
FROM (

SELECT /*+PARALLEL (18)*/
    FECHA, 
    CASE WHEN GESTIONES='C' THEN SUM(CUENTA) END CUMPLIDAS_TOTALES,
    CASE WHEN GESTIONES='P' THEN SUM(CUENTA) END PENDIENTES_TOTALES,
    CASE WHEN GESTIONES IN ('P','C','R') THEN SUM(CUENTA) END TOTALES,
    CASE WHEN GESTIONES='C' AND ORGANIZACION=100 THEN SUM(CUENTA) END CUMPLIDAS_LPC,
    CASE WHEN GESTIONES='P' AND ORGANIZACION=100 THEN SUM(CUENTA) END PENDIENTES_LCP,
    CASE WHEN GESTIONES IN ('P','C','R') AND ORGANIZACION=100 THEN SUM(CUENTA) END TOTALES_LPC,
    CASE WHEN GESTIONES='C' AND ORGANIZACION=110 THEN SUM(CUENTA) END CUMPLIDAS_DILISA,
    CASE WHEN GESTIONES='P' AND ORGANIZACION=110 THEN SUM(CUENTA) END PENDIENTES_DILISA,
    CASE WHEN GESTIONES IN ('P','C','R') AND ORGANIZACION=110 THEN SUM(CUENTA) END TOTALES_DILISA,
    CASE WHEN GESTIONES='C' AND ORGANIZACION=200 THEN SUM(CUENTA) END CUMPLIDAS_SBB_VISA,
    CASE WHEN GESTIONES='P' AND ORGANIZACION=200 THEN SUM(CUENTA) END PENDIENTES_SBB_VISA,
    CASE WHEN GESTIONES IN ('P','C','R') AND ORGANIZACION=200 THEN SUM(CUENTA) END TOTALES_SBB_VISA,
    CASE WHEN GESTIONES='C' AND ORGANIZACION=210 THEN SUM(CUENTA) END CUMPLIDAS_SBB_TD,
    CASE WHEN GESTIONES='P' AND ORGANIZACION=210 THEN SUM(CUENTA) END PENDIENTES_SBB_TD,
    CASE WHEN GESTIONES IN ('P','C','R') AND ORGANIZACION=210 THEN SUM(CUENTA) END TOTALES_SBB_TD,
    CASE WHEN GESTIONES='C' AND ORGANIZACION=230 THEN SUM(CUENTA) END CUMPLIDAS_MP,
    CASE WHEN GESTIONES='P' AND ORGANIZACION=230 THEN SUM(CUENTA) END PENDIENTES_MP,
    CASE WHEN GESTIONES IN ('P','C','R') AND ORGANIZACION=230 THEN SUM(CUENTA) END TOTALES_MP
    FROM (

SELECT
    TRUNC(A.PPDUE) FECHA, 
    A.PPFLAG GESTIONES, 
	CASE WHEN B.U6ORG IS NULL THEN 230
    WHEN B.U6ORG = 220 THEN 230
	ELSE B.U6ORG END ORGANIZACION,
	COUNT(A.PPACCT) CUENTA 
FROM 
	RCVRY.PTPSCHED A
	LEFT JOIN RCVRY.UDA6 B ON A.PPACCTG = B.U6ACCTG AND A.PPACCT = B.U6ACCT
	
WHERE 
TRUNC(A.PPDUE) BETWEEN TRUNC(TO_DATE('01/03/2026','dd/mm/yyyy')) AND TRUNC(TO_DATE(SYSDATE-1)) AND 
A.PPFLAG IN ('C','P','R') AND
A.PPACCTG IN ('6','5')
GROUP BY A.PPDUE,A.PPFLAG,B.U6ORG

)
GROUP BY FECHA,GESTIONES,ORGANIZACION
)
GROUP BY FECHA
ORDER BY 1

/

SELECT /*+PARALLEL (18)*/
P1.AÑO, 
P1.MES, 
P1.DIA, 
P1.CUENTAS AS PP, 
NVL(P2.CUENTAS/P1.CUENTAS,0) AS PCT_CUMPL, 
P2.CUENTAS AS PP_CUMPL, 
NVL(P3.CUENTAS,0) AS PP_PEND,
PMTAMT
FROM 

(SELECT TO_NUMBER(TO_CHAR(PPDUE, 'YYYY')) AS AÑO, TO_NUMBER(TO_CHAR(PPDUE, 'MM')) AS MES, TO_NUMBER(TO_CHAR(PPDUE, 'DD')) AS DIA, COUNT(PPACCT) AS CUENTAS
FROM rcvry.PTPSCHED
WHERE TRUNC(PPDUE) >= TRUNC(TO_DATE('01/03/2026','dd/mm/yyyy')) AND TRUNC(PPDUE) <= TRUNC(TO_DATE('31/03/2026','dd/mm/yyyy'))
AND PPFLAG in ('P','C','R')
GROUP BY TO_NUMBER(TO_CHAR(PPDUE, 'YYYY')), TO_NUMBER(TO_CHAR(PPDUE, 'MM')), TO_NUMBER(TO_CHAR(PPDUE, 'DD'))
ORDER BY 2) P1

LEFT OUTER JOIN

(SELECT TO_NUMBER(TO_CHAR(PPDUE, 'YYYY')) AS AÑO, TO_NUMBER(TO_CHAR(PPDUE, 'MM')) AS MES, TO_NUMBER(TO_CHAR(PPDUE, 'DD')) AS DIA, COUNT(PPACCT) AS CUENTAS
FROM rcvry.PTPSCHED
WHERE TRUNC(PPDUE) >= TRUNC(TO_DATE('01/03/2026','dd/mm/yyyy')) AND TRUNC(PPDUE) <= TRUNC(TO_DATE('31/03/2026','dd/mm/yyyy'))
AND PPFLAG = 'C'
GROUP BY TO_NUMBER(TO_CHAR(PPDUE, 'YYYY')), TO_NUMBER(TO_CHAR(PPDUE, 'MM')), TO_NUMBER(TO_CHAR(PPDUE, 'DD'))
ORDER BY 2) P2

ON P1.AÑO = P2.AÑO
AND P1.MES = P2.MES
AND P1.DIA = P2.DIA

LEFT OUTER JOIN

(SELECT TO_NUMBER(TO_CHAR(PPDUE, 'YYYY')) AS AÑO, TO_NUMBER(TO_CHAR(PPDUE, 'MM')) AS MES, TO_NUMBER(TO_CHAR(PPDUE, 'DD')) AS DIA, COUNT(PPACCT) AS CUENTAS
FROM rcvry.PTPSCHED
WHERE TRUNC(PPDUE) >= TRUNC(TO_DATE('01/03/2026','dd/mm/yyyy')) AND TRUNC(PPDUE) <= TRUNC(TO_DATE('31/03/2026','dd/mm/yyyy'))
AND PPFLAG = 'P'
GROUP BY TO_NUMBER(TO_CHAR(PPDUE, 'YYYY')), TO_NUMBER(TO_CHAR(PPDUE, 'MM')), TO_NUMBER(TO_CHAR(PPDUE, 'DD'))
ORDER BY 2) P3

ON P1.AÑO = P3.AÑO
AND P1.MES = P3.MES
AND P1.DIA = P3.DIA

LEFT JOIN 

(SELECT
TO_NUMBER(TO_CHAR(PMEDATE, 'MM')) AS MES, TO_NUMBER(TO_CHAR(PMEDATE, 'DD')) AS DIA, sum(PMTAMT)PMTAMT
FROM rcvry.PMTFIL
WHERE TRUNC(PMEDATE) >= TRUNC(TO_DATE('01/03/2026','dd/mm/yyyy')) AND TRUNC(PMEDATE) <= TRUNC(TO_DATE('31/03/2026','dd/mm/yyyy'))
AND (PMAGENCY IS NULL OR PMAGENCY LIKE 'DA%' OR PMAGENCY LIKE 'LA%' OR PMAGENCY LIKE 'SA%')
GROUP BY TO_NUMBER(TO_CHAR(PMEDATE, 'MM')), TO_NUMBER(TO_CHAR(PMEDATE, 'DD')))P4

ON P1.MES = P4.MES

ORDER BY 1, 2, 3
