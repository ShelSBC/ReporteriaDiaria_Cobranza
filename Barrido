SELECT /*+PARALLEL(18)*/
 Q4.RESP as "Responsable",
 Q4.DMAGENCY as "Agencia Actual",
 Q2.U6ORG as "Organización",
 Q4.RESP as "Asignación",
 Q1.PMACCT as "No. Cuenta",
 Q4.DMBRANCH as "Almacen",
 Q2.U6CYCDUE AS "CD Inicial",
 Q3.U6BLOCKCODE1 as "Bloqueo 1",
 Q3.U6BLOCKCODE2 as "Bloqueo 2",
 Q4.DMPAYAMT as "Monto U. Pago",
 Q4.DMPAYDT as "Fecha U. Pago",
 Q2.DMCURBAL as "Saldo Begin",
 Q1.PAGOS as "Pagos del mes",
 Q4.DMCURBAL as "Saldo Total",
 Q1.PAGOS/Q2.DMCURBAL as "% Pagos",
 1-(Q1.PAGOS/Q2.DMCURBAL) as "% Quitas",
 CASE WHEN (1-(Q1.PAGOS/Q2.DMCURBAL))<0.5 THEN '-50'
      WHEN (1-(Q1.PAGOS/Q2.DMCURBAL))>=0.5 AND (1-(Q1.PAGOS/Q2.DMCURBAL))<0.6 THEN '50-60'
      WHEN (1-(Q1.PAGOS/Q2.DMCURBAL))>=0.6 AND (1-(Q1.PAGOS/Q2.DMCURBAL))<0.7 THEN '60-70'
      WHEN (1-(Q1.PAGOS/Q2.DMCURBAL))>=0.7 AND (1-(Q1.PAGOS/Q2.DMCURBAL))<0.8 THEN '70-80'
      WHEN (1-(Q1.PAGOS/Q2.DMCURBAL))>=0.8 THEN '+80' ELSE '0' END as "Rango",
 Q3.U6CYCDUE AS "CD Final",
 SUBSTR(Q4.DMLABEL1,1,1) as "Nodo"

FROM 

(SELECT PMACCT,PMACCTG, SUM(PMTAMT) PAGOS FROM RCVRY.PMTFIL
WHERE PMACCTG  IN ('5','6')
AND TRUNC(PMEDATE) BETWEEN '01-Abr-2026' AND '30-Abr-2026'
AND(PMAGENCY LIKE 'DA%' OR PMAGENCY LIKE 'DK%' OR PMAGENCY LIKE 'DQ%' OR PMAGENCY LIKE 'LA%' OR PMAGENCY LIKE 'LK%'OR PMAGENCY LIKE 'SA%' OR 
    PMAGENCY LIKE 'SK%' OR PMAGENCY LIKE 'MA%' OR PMAGENCY LIKE 'MK%' OR PMAGENCY LIKE 'DA%' OR PMAGENCY LIKE 'DK%' OR PMAGENCY LIKE 'DQ%' OR 
    PMAGENCY LIKE 'LA%' OR PMAGENCY LIKE 'LK%' OR PMAGENCY LIKE 'SA%' OR PMAGENCY LIKE 'SK%' OR PMAGENCY LIKE 'MA%' OR PMAGENCY LIKE 'MK%')
GROUP BY PMACCT, PMACCTG)Q1

LEFT OUTER JOIN

(SELECT TRUNC(BEGINDT),DMACCT, DMACCTG, DMCURBAL, U6CYCDUE, U6ORG FROM RCVRY.DELQUDA_BEGIN
WHERE TRUNC(BEGINDT) = '01-Abr-2026'
AND DMACCT IN ( SELECT PMACCT
                FROM RCVRY.PMTFIL
                WHERE PMACCTG IN  ('6','5')
                AND TRUNC(PMEDATE) BETWEEN '01-Abr-2026' AND '30-Abr-2026'
                AND (PMAGENCY LIKE 'DA%' OR PMAGENCY LIKE 'DK%' OR PMAGENCY LIKE 'DQ%' OR PMAGENCY LIKE 'LA%' OR PMAGENCY LIKE 'LK%'OR 
                     PMAGENCY LIKE 'SA%' OR PMAGENCY LIKE 'SK%' OR PMAGENCY LIKE 'MA%' OR PMAGENCY LIKE 'MK%' OR PMAGENCY LIKE 'DA%' OR 
                     PMAGENCY LIKE 'DK%' OR PMAGENCY LIKE 'DQ%' OR PMAGENCY LIKE 'LA%' OR PMAGENCY LIKE 'LK%' OR PMAGENCY LIKE 'SA%' OR 
                     PMAGENCY LIKE 'SK%' OR PMAGENCY LIKE 'MA%' OR PMAGENCY LIKE 'MK%'))
                     
UNION ALL 

SELECT TRUNC(BEGINDT),DMACCT, DMACCTG, DMCURBAL, U5CYCDUE, U5ORG FROM RCVRY.DELQUDA_BEGIN_MP
WHERE TRUNC(BEGINDT) = '01-Abr-2026'
