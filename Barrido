     or PMAGENCY like 'SA%' or PMAGENCY like 'SK%' or PMAGENCY like 'MA%' or PMAGENCY like 'MK%')
)
)Q3

on Q1.PMACCT = Q3.U5ACCT

left outer join

(
select DMACCT, DMPAYDT, DMPAYAMT, DMBRANCH, DMAGENCY, DMQUE, DMLABEL1, DMCURBAL 
from RCVRY.DELQMST
where DMACCTG = '5' 
and DMACCT in (
select PMACCT
from RCVRY.PMTFIL
where PMACCTG = '5'
and (trunc(PMEDATE)>= '01-Mar-2026' and trunc(PMEDATE)<= '31-Mar-2026')
and (PMAGENCY like 'DA%' or PMAGENCY like 'DK%' or PMAGENCY like 'DQ%' or PMAGENCY like 'LA%' or PMAGENCY like 'LK%'
     or PMAGENCY like 'SA%' or PMAGENCY like 'SK%' or PMAGENCY like 'MA%' or PMAGENCY like 'MK%')
)
)Q4

on Q1.PMACCT = Q4.DMACCT

left outer join

(
select AGAGENCY, AGCITY
from RCVRY.AGENCY
)Q5

on Q4.DMAGENCY = Q5.AGAGENCY

where Q4.DMCURBAL <> '.0'
and (Q3.U5BLOCKCODE1 = 'A' or Q3.U5BLOCKCODE1 ='K')
and Q3.U5CYCDUE >= '2'

