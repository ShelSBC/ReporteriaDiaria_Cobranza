                 FROM RCVRY.PMTFIL
                 WHERE PMACCTG IN ('5','6')
                 AND TRUNC(PMEDATE) BETWEEN '01-Abr-2026' AND '30-Abr-2026'
                 AND (PMAGENCY LIKE 'DA%' OR PMAGENCY LIKE 'DK%' OR PMAGENCY LIKE 'DQ%' OR PMAGENCY LIKE 'LA%' OR PMAGENCY LIKE 'LK%'OR 
                      PMAGENCY LIKE 'SA%' OR PMAGENCY LIKE 'SK%' OR PMAGENCY LIKE 'MA%' OR PMAGENCY LIKE 'MK%' OR PMAGENCY LIKE 'DA%' OR 
                      PMAGENCY LIKE 'DK%' OR PMAGENCY LIKE 'DQ%' OR PMAGENCY LIKE 'LA%' OR PMAGENCY LIKE 'LK%' OR PMAGENCY LIKE 'SA%' OR 
                      PMAGENCY LIKE 'SK%' OR PMAGENCY LIKE 'MA%' OR PMAGENCY LIKE 'MK%'))
